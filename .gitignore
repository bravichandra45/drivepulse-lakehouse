# Secrets & local config
.env
.databrickscfg
*.pem
*.key

# Claude Code: commit settings.json, ignore personal/secret overrides
.claude/settings.local.json

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
*.egg-info/

# Data — never commit raw datasets (but DO version the reproducible download script).
# Granular form: a bare `data/` exclusion can't be un-ignored per-file, so ignore contents
# and re-include the script explicitly.
/data/*
!/data/claims/
/data/claims/*
!/data/claims/download_all_sources.py
*.csv
*.parquet
*.zip
!docs/**/*.csv

# Databricks bundle state
.databricks/
.bundle/

# IDE / OS
.idea/
.vscode/
.DS_Store
