# DrivePulse Lakehouse — copy to `.env` and fill in. NEVER commit `.env`.
# The Databricks CLI reads auth from ~/.databrickscfg (see README SETUP),
# so these are mainly for local scripts (dataset download, Event Hubs replay).

# --- Databricks (local scripts / SDK) ---------------------------------------
# Prefer using a named CLI profile instead of putting the token here.
DATABRICKS_HOST=https://adb-REPLACE_ME.0.azuredatabricks.net
DATABRICKS_CONFIG_PROFILE=drivepulse

# --- Azure Event Hubs (telemetry stream) ------------------------------------
# Store the real value in a Databricks secret scope; this is for local replay only.
EVENTHUBS_CONNECTION_STRING=Endpoint=sb://REPLACE.servicebus.windows.net/;SharedAccessKeyName=...;SharedAccessKey=...
EVENTHUBS_NAME=telemetry

# --- ADLS Gen2 (only if a local script needs direct access) -----------------
ADLS_ACCOUNT_NAME=REPLACE_ME
ADLS_CONTAINER=drivepulse

# --- Dataset download (Kaggle for Porto Seguro / Allstate) ------------------
KAGGLE_USERNAME=REPLACE_ME
KAGGLE_KEY=REPLACE_ME
